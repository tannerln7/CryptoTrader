# Copy this file to /etc/market-recorder/<instance>.env before enabling
# market-recorder@<instance>.service.
#
# The systemd template runs the foreground service-worker path directly so the
# worker remains compatible with `market-recorder status` and `health`, while
# systemd owns lifecycle operations such as start, stop, and restart.
#
# One active systemd-managed recorder worker is supported per repo checkout,
# because repo-scoped service-control state lives under <repo>/data/service/.

MARKET_RECORDER_REPO_ROOT=/opt/cryptotrader
MARKET_RECORDER_PYTHON=/opt/cryptotrader/.venv/bin/python
MARKET_RECORDER_CONFIG=/opt/cryptotrader/config/config.example.yaml

# Optional overrides. The unit already defaults these values, so uncomment only
# when an instance needs non-default behavior.
# MARKET_RECORDER_LOG_LEVEL=INFO
# MARKET_RECORDER_HEALTH_INTERVAL_SECONDS=10