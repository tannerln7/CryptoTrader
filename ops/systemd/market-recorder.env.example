# Copy this file to /etc/CryptoTrader/<instance>.env before enabling
# market-recorder@<instance>.service.
#
# The systemd template runs the foreground service-worker path directly so the
# worker owns the control socket and runtime health surface while systemd owns
# lifecycle operations such as start, stop, and restart.

MARKET_RECORDER_CONFIG=/etc/CryptoTrader/production.yaml

# Optional overrides. The unit already defaults these values, so uncomment only
# when an instance needs non-default behavior.
# MARKET_RECORDER_LOG_LEVEL=INFO
# MARKET_RECORDER_HEALTH_INTERVAL_SECONDS=10