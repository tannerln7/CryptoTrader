[Unit]
Description=CryptoTrader market recorder (%I)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/market-recorder/%i.env
Environment=PYTHONUNBUFFERED=1
Environment=MARKET_RECORDER_LOG_LEVEL=INFO
Environment=MARKET_RECORDER_HEALTH_INTERVAL_SECONDS=10
StateDirectory=market-recorder/%i
StateDirectoryMode=0750
UMask=0027
NoNewPrivileges=yes
PrivateTmp=yes
SyslogIdentifier=market-recorder@%i

# Uncomment and set these when the repo checkout and virtualenv are owned by
# a dedicated service account.
# User=market-recorder
# Group=market-recorder

ExecStartPre=/usr/bin/test -d ${MARKET_RECORDER_REPO_ROOT}
ExecStartPre=/usr/bin/test -x ${MARKET_RECORDER_PYTHON}
ExecStartPre=/usr/bin/test -f ${MARKET_RECORDER_CONFIG}
ExecStart=/usr/bin/env -C ${MARKET_RECORDER_REPO_ROOT} ${MARKET_RECORDER_PYTHON} -m market_recorder.cli --config ${MARKET_RECORDER_CONFIG} --data-root ${STATE_DIRECTORY} --log-level ${MARKET_RECORDER_LOG_LEVEL} service-worker --health-interval-seconds ${MARKET_RECORDER_HEALTH_INTERVAL_SECONDS}

Restart=on-failure
RestartPreventExitStatus=2
RestartSec=5s
KillSignal=SIGTERM
TimeoutStopSec=30s

[Install]
WantedBy=multi-user.target